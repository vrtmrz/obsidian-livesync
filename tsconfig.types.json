{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "noEmit": false,
        "declaration": true,
        "emitDeclarationOnly": true,
        "outDir": "./_types"
    },
    "include": ["src/lib/**/*.ts"],
    "exclude": [
        "_types",
        "pouchdb-browser-webpack",
        "utils",
        "src/apps",
        "src/**/*.test.ts",
        "**/_test/**",
        "utilsdeno",
        "node_modules",
        "test/**/*.test.ts",
        "**/*.unit.spec.ts"
    ]
}
